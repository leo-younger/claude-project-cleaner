{
  "_comment": "Add these hooks to your project's .claude/settings.json to enable auto-cleanup",
  "_instructions": "Copy the hooks block below into .claude/settings.json under the 'hooks' key",

  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PROJECT_DIR}/.claude/skills/claude-project-cleaner/scripts/cooldown.py touch --project ${CLAUDE_PROJECT_DIR}",
            "timeout": 10
          }
        ]
      }
    ],

    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PROJECT_DIR}/.claude/skills/claude-project-cleaner/scripts/cooldown.py check --project ${CLAUDE_PROJECT_DIR}",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
